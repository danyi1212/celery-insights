{
    "name": "celery-insights",
    "private": true,
    "version": "0.2.0",
    "type": "module",
    "scripts": {
        "dev": "vite dev --port 3000",
        "build": "vite build",
        "start": "bun run bun-entry.ts",
        "lint": "eslint --max-warnings=0 app",
        "lint-fix": "eslint --max-warnings=0 app --fix",
        "e2e": "playwright test --config e2e/playwright.config.ts",
        "e2e:ui": "playwright test --config e2e/playwright.config.ts --ui",
        "e2e:headed": "playwright test --config e2e/playwright.config.ts --headed",
        "test": "vitest run",
        "test:watch": "vitest",
        "dev:surreal": "surreal start --bind 0.0.0.0:8557 --user root --pass root memory",
        "dev:all": "concurrently \"bun run dev:surreal\" \"cd ../server && python run.py\" \"bun dev\""
    },
    "dependencies": {
        "@surrealdb/wasm": "^3.0.1",
        "@tailwindcss/vite": "^4.2.1",
        "@tanstack/react-query": "^5.90.21",
        "@tanstack/react-router": "^1.162.9",
        "@tanstack/react-table": "^8.21.3",
        "@uiw/react-json-view": "^2.0.0-alpha.41",
        "@xyflow/react": "^12",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "date-fns": "^3.6.0",
        "html-to-image": "^1.11.11",
        "lucide-react": "^0.575.0",
        "minidenticons": "^4.2.1",
        "radix-ui": "^1.4.3",
        "react": "^19.1",
        "react-dom": "^19.1",
        "react-joyride": "^2.8.2",
        "react-shiki": "^0.9.1",
        "react-transition-group": "^4.4.5",
        "recharts": "^3.7.0",
        "semver": "^7.6.3",
        "shiki": "^3.22.0",
        "string-to-color": "^2.2.2",
        "surrealdb": "^2.0.0",
        "tailwind-merge": "^3.5.0",
        "tailwindcss": "^4.2.1",
        "tailwindcss-animate": "^1.0.7",
        "uuid": "^10.0.0",
        "zod": "^4.3.6",
        "zustand": "^4.5.5"
    },
    "devDependencies": {
        "@playwright/test": "^1.58.2",
        "@tanstack/router-plugin": "^1.162.9",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.2",
        "@testing-library/user-event": "^14.6.1",
        "@types/react": "^19",
        "@types/react-dom": "^19",
        "@types/react-transition-group": "^4.4.12",
        "@types/semver": "^7.5.8",
        "@types/uuid": "^10.0.0",
        "@typescript-eslint/eslint-plugin": "^8.1.0",
        "@typescript-eslint/parser": "^8.1.0",
        "@vitejs/plugin-react": "^4.3.4",
        "concurrently": "^9.2.1",
        "eslint": "^8.57.0",
        "eslint-plugin-jsx-a11y": "^6.9.0",
        "eslint-plugin-prettier": "^5.2.1",
        "eslint-plugin-react": "^7.35.0",
        "eslint-plugin-react-hooks": "^4.6.2",
        "happy-dom": "^20.7.0",
        "prettier": "^3.3.3",
        "typescript": "^5.5.4",
        "vite": "^6.0.0",
        "vite-tsconfig-paths": "^5.0.1",
        "vitest": "^4.0.18"
    },
    "prettier": {
        "tabWidth": 4,
        "semi": false,
        "printWidth": 120
    }
}
