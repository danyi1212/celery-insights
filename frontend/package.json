{
    "name": "celery-insights",
    "private": true,
    "version": "0.2.0",
    "type": "module",
    "scripts": {
        "dev": "vite dev --port 3000",
        "build": "vite build",
        "start": "bun run bun-entry.ts",
        "typecheck": "tsc --noEmit",
        "format": "oxfmt --check app",
        "format-fix": "oxfmt app",
        "lint": "oxlint --deny-warnings app",
        "lint-fix": "oxlint --deny-warnings --fix app",
        "e2e": "playwright test --config e2e/playwright.config.ts",
        "e2e:ui": "playwright test --config e2e/playwright.config.ts --ui",
        "e2e:headed": "playwright test --config e2e/playwright.config.ts --headed",
        "test": "vitest run",
        "test:watch": "vitest",
        "dev:surreal": "surreal start --bind 0.0.0.0:8557 --username root --password root memory",
        "dev:all": "concurrently \"bun run dev:surreal\" \"cd ../server && python run.py\" \"bun dev\""
    },
    "dependencies": {
        "@surrealdb/wasm": "^3.0.1",
        "@tailwindcss/vite": "^4.2.1",
        "@tanstack/react-hotkeys": "^0.4.1",
        "@tanstack/react-query": "^5.90.21",
        "@tanstack/react-router": "^1.166.2",
        "@tanstack/react-table": "^8.21.3",
        "@uiw/react-json-view": "^2.0.0-alpha.41",
        "@xyflow/react": "^12",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "date-fns": "^3.6.0",
        "html-to-image": "^1.11.11",
        "lucide-react": "^0.575.0",
        "minidenticons": "^4.2.1",
        "radix-ui": "^1.4.3",
        "react": "^19.2",
        "react-dom": "^19.2",
        "react-joyride": "^2.8.2",
        "react-shiki": "^0.9.1",
        "react-transition-group": "^4.4.5",
        "recharts": "^3.7.0",
        "semver": "^7.6.3",
        "shiki": "^4.0.1",
        "string-to-color": "^2.2.2",
        "surrealdb": "^2.0.1",
        "tailwind-merge": "^3.5.0",
        "tailwindcss": "^4.2.1",
        "tailwindcss-animate": "^1.0.7",
        "uuid": "^10.0.0",
        "zod": "^4.3.6",
        "zustand": "^5.0.11"
    },
    "devDependencies": {
        "@playwright/test": "^1.58.2",
        "@tanstack/router-plugin": "^1.166.2",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.2",
        "@testing-library/user-event": "^14.6.1",
        "@types/react": "^19",
        "@types/react-dom": "^19",
        "@types/react-transition-group": "^4.4.12",
        "@types/semver": "^7.5.8",
        "@types/uuid": "^10.0.0",
        "@vitejs/plugin-react": "^5.1.4",
        "concurrently": "^9.2.1",
        "happy-dom": "^20.7.0",
        "oxfmt": "^0.36.0",
        "oxlint": "^1.51.0",
        "typescript": "^5.9.3",
        "vite": "^7.3.1",
        "vite-tsconfig-paths": "^5.0.1",
        "vitest": "^4.0.18"
    }
}
