{
    "name": "celery-insights",
    "private": true,
    "version": "0.2.0",
    "packageManager": "bun@1.3.10",
    "type": "module",
    "scripts": {
        "dev": "bunx --bun vite dev --port 3000",
        "build": "bunx --bun vite build",
        "start": "bun run bun-entry.ts",
        "typecheck": "tsc --noEmit",
        "check:frontend": "bun run typecheck && bun run lint && bun run format && bun run test",
        "format": "oxfmt --check src runtime bun-entry.ts e2e tooling vite.config.ts vitest.config.ts vitest.setup.ts",
        "format-fix": "oxfmt src runtime bun-entry.ts e2e tooling vite.config.ts vitest.config.ts vitest.setup.ts",
        "lint": "oxlint --deny-warnings src runtime bun-entry.ts e2e tooling vite.config.ts vitest.config.ts vitest.setup.ts",
        "lint-fix": "oxlint --deny-warnings --fix src runtime bun-entry.ts e2e tooling vite.config.ts vitest.config.ts vitest.setup.ts",
        "e2e": "playwright test --config e2e/playwright.config.ts",
        "e2e:ui": "playwright test --config e2e/playwright.config.ts --ui",
        "e2e:headed": "playwright test --config e2e/playwright.config.ts --headed",
        "test": "vitest run",
        "test:watch": "vitest",
        "dev:surreal": "surreal start --bind 0.0.0.0:8557 --username root --password root memory",
        "dev:server": "cd server && python run.py",
        "dev:all": "concurrently \"bun run dev:surreal\" \"bun run dev:server\" \"bun run dev\""
    },
    "dependencies": {
        "@floating-ui/react": "^0.27.19",
        "@mdx-js/react": "^3.1.1",
        "@surrealdb/wasm": "^3.0.3",
        "@tailwindcss/vite": "^4.2.1",
        "@tanstack/react-hotkeys": "^0.4.1",
        "@tanstack/react-query": "^5.90.21",
        "@tanstack/react-router": "^1.167.1",
        "@tanstack/react-table": "^8.21.3",
        "@uiw/react-json-view": "^2.0.0-alpha.41",
        "@vercel/analytics": "^2.0.1",
        "@xyflow/react": "^12.10.1",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "date-fns": "^4.1.0",
        "html-to-image": "^1.11.13",
        "lucide-react": "^1.6.0",
        "minidenticons": "^4.2.1",
        "motion": "^12.36.0",
        "radix-ui": "^1.4.3",
        "react": "^19.2.4",
        "react-dom": "^19.2.4",
        "react-joyride": "^2.9.3",
        "react-shiki": "^0.9.2",
        "react-transition-group": "^4.4.5",
        "recharts": "^3.8.0",
        "rehype-slug": "^6.0.0",
        "remark-gfm": "^4.0.1",
        "semver": "^7.7.4",
        "shiki": "^4.0.2",
        "string-to-color": "^2.2.2",
        "surrealdb": "^2.0.2",
        "tailwind-merge": "^3.5.0",
        "tailwindcss": "^4.2.1",
        "tailwindcss-animate": "^1.0.7",
        "uuid": "^13.0.0",
        "zod": "^3.25.76",
        "zustand": "^5.0.11"
    },
    "devDependencies": {
        "@playwright/test": "^1.58.2",
        "@tanstack/router-plugin": "^1.166.10",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.2",
        "@testing-library/user-event": "^14.6.1",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@types/react-transition-group": "^4.4.12",
        "@types/semver": "^7.7.1",
        "@types/uuid": "^11.0.0",
        "@mdx-js/rollup": "^3.1.1",
        "@vitejs/plugin-react": "^6.0.1",
        "concurrently": "^9.2.1",
        "happy-dom": "^20.8.4",
        "oxfmt": "^0.40.0",
        "oxlint": "^1.55.0",
        "typescript": "^5.9.3",
        "vite": "^8.0.0",
        "vitest": "^4.1.0"
    }
}
